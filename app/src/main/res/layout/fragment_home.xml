<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- AppBar with collapsing header -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:elevation="0dp">

        <!-- Top Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="12dp"
            android:paddingStart="@dimen/screen_padding_horizontal"
            android:paddingEnd="@dimen/screen_padding_horizontal">

            <!-- Greeting Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Hamburger Menu -->
                <ImageButton
                    android:id="@+id/btn_side_menu"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="12dp"
                    android:background="@android:color/transparent"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    app:tint="@color/text_primary"
                    android:contentDescription="Open Menu" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_regular"
                        android:text="Good Morning 👋"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_bold"
                        android:text="@string/app_name"
                        android:textColor="@color/brand_primary"
                        android:textSize="24sp"
                        android:letterSpacing="-0.02" />

                </LinearLayout>

                <!-- Notification Bell -->
                <ImageButton
                    android:id="@+id/btn_notification"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_icon_button"
                    android:src="@drawable/ic_notification"
                    android:padding="10dp"
                    android:contentDescription="Notifications" />

            </LinearLayout>

            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/search_bar_height"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_search_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/text_hint" />

                <TextView
                    android:id="@+id/tv_search_hint"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/nunito_regular"
                    android:text="@string/search_hint"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_filter"
                    app:tint="@color/text_secondary" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scroll_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ===== BANNER SLIDER ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="16dp"
                android:paddingStart="@dimen/screen_padding_horizontal"
                android:paddingEnd="@dimen/screen_padding_horizontal">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/vp_banner"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/banner_height"
                    android:clipToPadding="false"
                    android:clipChildren="false" />

                <!-- Dots Indicator -->
                <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
                    android:id="@+id/dots_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    app:dotsColor="@color/brand_primary"
                    app:dotsCornerRadius="4dp"
                    app:dotsSize="7dp"
                    app:dotsSpacing="5dp"
                    app:dotsWidthFactor="2.5"
                    app:selectedDotColor="@color/brand_primary" />

            </LinearLayout>

            <!-- ===== CATEGORIES ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/screen_padding_horizontal"
                    android:paddingEnd="@dimen/screen_padding_horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/nunito_bold"
                        android:text="@string/shop_by_category"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_see_all_categories"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_semibold"
                        android:text="@string/see_all"
                        android:textColor="@color/brand_primary"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- Category RecyclerView (horizontal) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_categories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:clipToPadding="false"
                    android:paddingStart="@dimen/screen_padding_horizontal"
                    android:paddingEnd="@dimen/screen_padding_horizontal"
                    android:orientation="horizontal"
                    tools:listitem="@layout/item_category" />

            </LinearLayout>

            <!-- ===== FEATURED DEALS ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="28dp">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/screen_padding_horizontal"
                    android:paddingEnd="@dimen/screen_padding_horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/nunito_bold"
                        android:text="@string/featured_deals"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_see_all_deals"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_semibold"
                        android:text="@string/see_all"
                        android:textColor="@color/brand_primary"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- Horizontal products -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_featured"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:clipToPadding="false"
                    android:paddingStart="@dimen/screen_padding_horizontal"
                    android:paddingEnd="@dimen/screen_padding_horizontal"
                    android:orientation="horizontal"
                    tools:listitem="@layout/item_product_horizontal" />

            </LinearLayout>

            <!-- ===== POPULAR PRODUCTS (Grid) ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="28dp">

                <!-- Section Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/screen_padding_horizontal"
                    android:paddingEnd="@dimen/screen_padding_horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/nunito_bold"
                        android:text="@string/popular_products"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp" />

                    <TextView
                        android:id="@+id/tv_see_all_products"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/nunito_semibold"
                        android:text="@string/see_all"
                        android:textColor="@color/brand_primary"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- Grid RecyclerView (2 columns) - nested inside ScrollView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_products_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:paddingStart="@dimen/screen_padding_horizontal"
                    android:paddingEnd="@dimen/screen_padding_horizontal"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_product_grid" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>