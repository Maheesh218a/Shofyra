<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        ================================================================
        SHOFYRA THEME SYSTEM
        Based on Material3 DayNight — automatically switches LIGHT ↔ DARK
        ================================================================
    -->

    <!-- BASE THEME: DayNight handles system switching automatically -->
    <style name="Theme.Shofyra" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>

        <!-- Secondary / Accent -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>

        <!-- Backgrounds -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/nav_background</item>

        <!-- Window background -->
        <item name="android:windowBackground">@color/background</item>

        <!-- Elevation overlays for dark mode surfaces -->
        <item name="elevationOverlayEnabled">true</item>

        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Shofyra.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Shofyra.HeadlineMedium</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Shofyra.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Shofyra.BodyMedium</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Shofyra.LabelLarge</item>

        <!-- Material Components Styling -->
        <item name="materialButtonStyle">@style/Widget.Shofyra.Button</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.Shofyra.Button.Outlined</item>
        <item name="bottomNavigationStyle">@style/Widget.Shofyra.BottomNavigation</item>
        <item name="cardViewStyle">@style/Widget.Shofyra.CardView</item>
        <item name="toolbarStyle">@style/Widget.Shofyra.Toolbar</item>
    </style>

    <!-- SPLASH SCREEN THEME -->
    <style name="Theme.Shofyra.Splash" parent="Theme.Shofyra">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/brand_primary</item>
    </style>

    <!-- ===================== TYPOGRAPHY ===================== -->
    <style name="TextAppearance.Shofyra.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <style name="TextAppearance.Shofyra.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Shofyra.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">@font/nunito_regular</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Shofyra.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">@font/nunito_regular</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Shofyra.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">@font/nunito_semibold</item>
    </style>

    <!-- ===================== WIDGET STYLES ===================== -->

    <!-- Primary Button -->
    <style name="Widget.Shofyra.Button" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/button_primary</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="android:letterSpacing">0.02</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textSize">15sp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Outlined Button -->
    <style name="Widget.Shofyra.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Text-only Button -->
    <style name="Widget.Shofyra.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:fontFamily">@font/nunito_semibold</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.Shofyra.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/nav_background</item>
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
        <item name="elevation">8dp</item>
        <item name="itemRippleColor">@color/brand_primary_light</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.Shofyra.NavIndicator</item>
    </style>

    <style name="Widget.Shofyra.NavIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/brand_primary_light</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Shofyra.NavIndicator</item>
    </style>

    <style name="ShapeAppearance.Shofyra.NavIndicator" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- CardView -->
    <style name="Widget.Shofyra.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Toolbar -->
    <style name="Widget.Shofyra.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/surface</item>
        <item name="titleTextColor">@color/text_primary</item>
        <item name="titleTextAppearance">@style/TextAppearance.Shofyra.Toolbar.Title</item>
    </style>

    <style name="TextAppearance.Shofyra.Toolbar.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">20sp</item>
    </style>

</resources>